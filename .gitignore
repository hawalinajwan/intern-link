# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.run-logs/
.runtime/

# local backend runtime data
backend/php/storage/app.json
backend/php/storage/uploads/cv/*
!backend/php/storage/uploads/cv/.gitkeep
backend-php/uploads/cv/*
!backend-php/uploads/cv/.gitkeep

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend-php/.env
backend-node/.env
!.env.example
!.env.local.example
!backend-php/.env.example
!backend-node/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local Mac launchers and Codex workspace metadata
START_INTERN_LINK.command
STOP_INTERN_LINK.command

.codex

# local agent instructions and private working notes
AGENTS.md
CLAUDE.md
GEMINI.md
MIGRATE_TO_MAC.md
*-codex-prompts.md
*agent*.md
*AGENT*.md
